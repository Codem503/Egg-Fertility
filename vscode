"""
=============================================================
  Object Detection & Real-World Size Estimator using OpenCV
=============================================================
  Author  : Generated with Claude
  Purpose : Detect objects in an image or webcam feed and
            estimate their real-world dimensions using a
            known reference object (e.g., a standard coin).

  Usage:
    # Image mode (provide path to image):
        python object_size_detector.py --image path/to/image.jpg

    # Webcam mode (live detection):
        python object_size_detector.py --webcam

    # Custom reference width (in cm):
        python object_size_detector.py --image img.jpg --ref-width 2.426

  Reference object assumptions:
    - A US quarter coin (~2.426 cm wide) is placed in the
      LEFTMOST position of the scene, OR
    - You pass --ref-width with the real width of whatever
      object appears leftmost in the frame.
=============================================================
"""

import cv2
import numpy as np
import argparse
import sys


# ─────────────────────────────────────────────
#  CONFIGURATION  (tweak these to suit your scene)
# ─────────────────────────────────────────────
DEFAULT_REF_WIDTH_CM   = 2.426   # Real-world width of reference object (cm)
GAUSSIAN_BLUR_KERNEL   = (7, 7)  # Must be odd × odd
CANNY_THRESHOLD_LOW    = 35      # Lower  = more edges detected
CANNY_THRESHOLD_HIGH   = 100     # Higher = fewer, stronger edges
MIN_CONTOUR_AREA       = 500     # Pixels² — filters noise / tiny blobs
DILATION_ITERATIONS    = 2       # Thickens edges for better contour closure
FONT                   = cv2.FONT_HERSHEY_SIMPLEX


# ─────────────────────────────────────────────
#  STEP 1 — PREPROCESSING
# ─────────────────────────────────────────────
def preprocess(frame: np.ndarray) -> np.ndarray:
    """
    Prepare raw frame for contour detection:
      1. Grayscale   – removes colour noise
      2. Gaussian blur – smooths out texture / fine detail
      3. Canny edges  – finds strong intensity transitions
      4. Dilation     – closes small gaps so contours are sealed
    """
    gray    = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    blurred = cv2.GaussianBlur(gray, GAUSSIAN_BLUR_KERNEL, 0)
    edges   = cv2.Canny(blurred, CANNY_THRESHOLD_LOW, CANNY_THRESHOLD_HIGH)

    # Dilate edges so object outlines form closed loops
    kernel  = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
    dilated = cv2.dilate(edges, kernel, iterations=DILATION_ITERATIONS)

    return dilated


# ─────────────────────────────────────────────
#  STEP 2 — CONTOUR DETECTION & FILTERING
# ─────────────────────────────────────────────
def find_objects(processed: np.ndarray):
    """
    Find external contours and discard anything too small to be real.

    Returns a list of contours sorted left-to-right by their
    bounding-box centre (so the leftmost object = reference).
    """
    contours, _ = cv2.findContours(
        processed, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE
    )

    # Filter by minimum area to remove noise blobs
    filtered = [c for c in contours if cv2.contourArea(c) >= MIN_CONTOUR_AREA]

    # Sort contours left-to-right (reference object should be leftmost)
    filtered.sort(key=lambda c: cv2.boundingRect(c)[0])

    return filtered


# ─────────────────────────────────────────────
#  STEP 3 — PIXELS-PER-METRIC RATIO
# ─────────────────────────────────────────────
def compute_ppm(reference_contour, ref_width_cm: float) -> float:
    """
    Calculate pixels-per-cm using the leftmost (reference) contour.

    pixels_per_cm = pixel_width_of_reference / real_width_of_reference
    """
    x, y, w, h = cv2.boundingRect(reference_contour)
    pixels_per_cm = w / ref_width_cm
    return pixels_per_cm


# ─────────────────────────────────────────────
#  STEP 4 — BOUNDING BOX + SIZE LABEL
# ─────────────────────────────────────────────
def draw_object_info(
    frame:          np.ndarray,
    contour,
    pixels_per_cm:  float,
    is_reference:   bool = False
) -> None:
    """
    Draw a labelled bounding box on `frame` for the given contour.

    - Green box  = reference object (known real size)
    - Blue  box  = measured object  (size estimated via PPM ratio)
    """
    x, y, w, h = cv2.boundingRect(contour)

    # Convert pixel dimensions to centimetres
    width_cm  = w / pixels_per_cm
    height_cm = h / pixels_per_cm

    # Choose colour: green for reference, blue for others
    colour = (0, 200, 0) if is_reference else (255, 100, 0)
    label  = "REF"       if is_reference else "OBJ"

    # ── Draw bounding rectangle ──────────────────────────────
    cv2.rectangle(frame, (x, y), (x + w, y + h), colour, 2)

    # ── Draw centre crosshair ────────────────────────────────
    cx, cy = x + w // 2, y + h // 2
    cv2.drawMarker(frame, (cx, cy), colour,
                   cv2.MARKER_CROSS, 10, 1)

    # ── Build size text ──────────────────────────────────────
    size_text = f"{label}: {width_cm:.2f} x {height_cm:.2f} cm"

    # Background pill so text is readable on any background
    (tw, th), baseline = cv2.getTextSize(size_text, FONT, 0.5, 1)
    pad = 4
    cv2.rectangle(frame,
                  (x, y - th - 2 * pad),
                  (x + tw + 2 * pad, y),
                  colour, cv2.FILLED)
    cv2.putText(frame, size_text,
                (x + pad, y - pad),
                FONT, 0.5, (255, 255, 255), 1, cv2.LINE_AA)


# ─────────────────────────────────────────────
#  STEP 5 — PROCESS A SINGLE FRAME
# ─────────────────────────────────────────────
def process_frame(frame: np.ndarray, ref_width_cm: float):
    """
    Full pipeline for one frame:
      preprocess → find contours → compute PPM → annotate → return

    Returns:
        annotated  – BGR frame with boxes and labels
        debug_view – 4-panel diagnostic grid (grayscale / edges / etc.)
    """
    # Keep a clean copy for annotation
    annotated = frame.copy()

    # --- Preprocessing ---
    gray    = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
    blurred = cv2.GaussianBlur(gray, GAUSSIAN_BLUR_KERNEL, 0)
    edges   = cv2.Canny(blurred, CANNY_THRESHOLD_LOW, CANNY_THRESHOLD_HIGH)
    kernel  = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
    dilated = cv2.dilate(edges, kernel, iterations=DILATION_ITERATIONS)

    # --- Object detection ---
    contours = find_objects(dilated)

    if len(contours) == 0:
        cv2.putText(annotated, "No objects detected",
                    (20, 40), FONT, 0.8, (0, 0, 255), 2, cv2.LINE_AA)
        ppm = None
    else:
        # The leftmost contour is treated as the reference object
        ppm = compute_ppm(contours[0], ref_width_cm)

        for idx, cnt in enumerate(contours):
            draw_object_info(annotated, cnt, ppm, is_reference=(idx == 0))

    # ── HUD overlay ─────────────────────────────────────────
    obj_count = max(0, len(contours) - 1)   # exclude reference
    hud = (
        f"Objects: {obj_count}  |  "
        f"Ref width: {ref_width_cm:.3f} cm  |  "
        f"PPM: {ppm:.1f}" if ppm else "Place a reference object in frame"
    )
    cv2.putText(annotated, hud, (10, annotated.shape[0] - 10),
                FONT, 0.45, (200, 200, 200), 1, cv2.LINE_AA)

    # ── Debug 4-panel view ───────────────────────────────────
    gray_bgr    = cv2.cvtColor(gray,    cv2.COLOR_GRAY2BGR)
    blurred_bgr = cv2.cvtColor(blurred, cv2.COLOR_GRAY2BGR)
    edges_bgr   = cv2.cvtColor(edges,   cv2.COLOR_GRAY2BGR)

    h, w = frame.shape[:2]
    scale = 0.5
    def rs(img):
        return cv2.resize(img, (int(w * scale), int(h * scale)))

    top    = np.hstack([rs(gray_bgr),    rs(blurred_bgr)])
    bottom = np.hstack([rs(edges_bgr),   rs(annotated)])
    debug_view = np.vstack([top, bottom])

    # Label each panel
    labels = ["1. Grayscale", "2. Blurred",
              "3. Canny Edges", "4. Detected Objects"]
    positions = [
        (5, 20), (int(w * scale) + 5, 20),
        (5, int(h * scale) + 20), (int(w * scale) + 5, int(h * scale) + 20),
    ]
    for lbl, pos in zip(labels, positions):
        cv2.putText(debug_view, lbl, pos, FONT, 0.55,
                    (0, 255, 255), 1, cv2.LINE_AA)

    return annotated, debug_view


# ─────────────────────────────────────────────
#  STEP 6 — IMAGE MODE
# ─────────────────────────────────────────────
def run_image_mode(image_path: str, ref_width_cm: float) -> None:
    """Load a single image, process it, and display results."""

    frame = cv2.imread(image_path)
    if frame is None:
        print(f"[ERROR] Cannot load image: '{image_path}'")
        sys.exit(1)

    print(f"[INFO] Loaded image: {image_path}  ({frame.shape[1]}×{frame.shape[0]})")

    annotated, debug_view = process_frame(frame, ref_width_cm)

    cv2.imshow("Object Size Detector — Result", annotated)
    cv2.imshow("Debug View (4-panel)", debug_view)

    print("[INFO] Press any key to close.")
    cv2.waitKey(0)
    cv2.destroyAllWindows()


# ─────────────────────────────────────────────
#  STEP 7 — WEBCAM MODE  (real-time)
# ─────────────────────────────────────────────
def run_webcam_mode(ref_width_cm: float, camera_index: int = 0) -> None:
    """
    Open the default webcam and run detection on every frame.

    Keys:
        Q  – quit
        S  – save current annotated frame as 'snapshot.jpg'
        D  – toggle debug 4-panel view
    """
    cap = cv2.VideoCapture(camera_index)
    if not cap.isOpened():
        print(f"[ERROR] Cannot open camera index {camera_index}.")
        sys.exit(1)

    print("[INFO] Webcam started. Press Q to quit, S to snapshot, D to toggle debug.")

    show_debug = False

    while True:
        ret, frame = cap.read()
        if not ret:
            print("[WARN] Frame grab failed — retrying…")
            continue

        annotated, debug_view = process_frame(frame, ref_width_cm)

        if show_debug:
            cv2.imshow("Object Size Detector", debug_view)
        else:
            cv2.imshow("Object Size Detector", annotated)

        key = cv2.waitKey(1) & 0xFF
        if key == ord('q'):
            print("[INFO] Quitting.")
            break
        elif key == ord('s'):
            filename = "snapshot.jpg"
            cv2.imwrite(filename, annotated)
            print(f"[INFO] Snapshot saved → {filename}")
        elif key == ord('d'):
            show_debug = not show_debug
            mode = "debug" if show_debug else "annotated"
            print(f"[INFO] Switched to {mode} view.")

    cap.release()
    cv2.destroyAllWindows()


# ─────────────────────────────────────────────
#  ENTRY POINT
# ─────────────────────────────────────────────
def parse_args():
    parser = argparse.ArgumentParser(
        description="Detect objects and estimate real-world size using OpenCV.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  python object_size_detector.py --image objects.jpg
  python object_size_detector.py --image objects.jpg --ref-width 3.5
  python object_size_detector.py --webcam
  python object_size_detector.py --webcam --ref-width 2.426 --camera 1
        """
    )
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--image",  type=str,
                       help="Path to an input image file.")
    group.add_argument("--webcam", action="store_true",
                       help="Use webcam for real-time detection.")

    parser.add_argument("--ref-width", type=float,
                        default=DEFAULT_REF_WIDTH_CM,
                        help=f"Real-world width of the LEFTMOST reference "
                             f"object in cm (default: {DEFAULT_REF_WIDTH_CM}).")
    parser.add_argument("--camera", type=int, default=0,
                        help="Camera device index for webcam mode (default: 0).")
    return parser.parse_args()


def main():
    args = parse_args()

    print("=" * 55)
    print("  Object Size Detector — OpenCV")
    print("=" * 55)
    print(f"  Reference object width : {args.ref_width:.3f} cm")
    print(f"  Min contour area       : {MIN_CONTOUR_AREA} px²")
    print(f"  Canny thresholds       : {CANNY_THRESHOLD_LOW} / {CANNY_THRESHOLD_HIGH}")
    print("=" * 55)

    if args.webcam:
        run_webcam_mode(args.ref_width, args.camera)
    else:
        run_image_mode(args.image, args.ref_width)


if __name__ == "__main__":
    main()
